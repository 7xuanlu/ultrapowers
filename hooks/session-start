#!/usr/bin/env bash
# SessionStart hook (ultrapowers): remove the legacy ~/.claude/workflows/ symlink that older
# versions created for by-name Workflow dispatch. The engine is now dispatched by scriptPath
# (so it stays out of the slash list and can't be model-invoked, which would bypass the gates).
# Idempotent: removes only our own symlink slot, never a real file a user may have placed there.
set -euo pipefail

LINK="${HOME}/.claude/workflows/ultrapowers-development.js"

if [ -L "${LINK}" ]; then
  rm -f "${LINK}"
fi

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":""}}\n'
exit 0
